<!DOCTYPE html>
<html lang="<%= page_lang() %>">

<head>

  <!-- Minima -->
  <!-- Hexo theme created by @adisaktijrs -->

  <!-- Basic Page Needs
  –––––––––––––––––––––––––––––––––––––––––––––––––– -->
  <meta charset="utf-8">

  <%
  if (!config.author) {
    config.author = ""
  }

  var siteTitle = config.title.split('|')[0].trim();
  var pageTitle;
  if (is_archive()){
    pageTitle = __('archive.title') + ' | ' + siteTitle;
  } else if (is_post()){
    pageTitle = page.title + ' | ' + siteTitle;
  } else if (is_page()){
    pageTitle = page.title + ' | ' + siteTitle;
  } else if (is_tag()){
    pageTitle = __('tag.related_to') + ' ' + page.tag + ' | ' + siteTitle;
  } else {
    pageTitle = config.title;
  }
  var pageDescription;
  if (is_page() && page.description) {
    pageDescription = page.description;
  } else if ((is_post() || is_page()) && page.summary) {
    pageDescription = page.summary;
  } else if (page.content) {
    pageDescription = strip_html(page.content).replace(/\n/g, " ").replace(/^\s*/, '').replace(/\s*$/, '').substring(0, 150);
  } else {
    pageDescription = config.description;
  }
  %>
  <title><%= pageTitle %></title>
  <% if (config.sitemap) { %>
  <link rel="sitemap" href="<%-config.url + '/' + config.sitemap.path %>" />
  <% } %>
  <link rel="canonical" href="<%= url.replace(/index\.html$/, '') %>">
  <link rel="alternate" hreflang="<%= page_lang() === 'zh' ? 'en' : 'zh' %>" href="<%= config.url %><%= alternate_url() %>" />
  <link rel="alternate" hreflang="<%= page_lang() %>" href="<%= url.replace(/index\.html$/, '') %>" />
  <link rel="alternate" hreflang="x-default" href="<%= page_lang() === 'en' ? url.replace(/index\.html$/, '') : config.url + alternate_url() %>" />
  <meta name="description" content="<%= pageDescription %>">
  <% if (config.keywords) { %>
  <meta name="keywords" content="<%= config.keywords %>">
  <% } %>
  <meta name="author" content="<%- config.author %>">
  <%
  var ogImage = theme.thumbnail;
  if ((is_post() || is_page()) && page.thumbnail) {
    ogImage = page.thumbnail;
  }
  %>
  <meta property="og:image" content="<%-config.url + ogImage %>">
  <meta property="og:site_name" content="<%= config.title %>" />
  <% if (is_post()) { %>
  <meta property="og:type" content="article" />
  <meta property="article:published_time" content="<%= page.date.toISOString() %>" />
  <meta property="article:modified_time" content="<%= (page.updated || page.date).toISOString() %>" />
  <meta property="article:author" content="<%= config.author %>" />
  <% if (page.tags && page.tags.length) { page.tags.forEach(function(tag) { %>
  <meta property="article:tag" content="<%= tag.name %>" />
  <% }); } %>
  <% } else { %>
  <meta property="og:type" content="website" />
  <% } %>
  <meta property="og:title" content="<%= pageTitle %>" />
  <meta property="og:locale" content="<%= page_lang() === 'zh' ? 'zh_CN' : 'en_US' %>" />
  <meta property="og:locale:alternate" content="<%= page_lang() === 'zh' ? 'en_US' : 'zh_CN' %>" />
  <meta property="og:description" content="<%= pageDescription %>">
  <meta property="og:url" content="<%= url.replace(/index\.html$/, '') %>" />

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:site" content="@Clean993">
  <meta name="twitter:creator" content="@Clean993">
  <meta name="twitter:title" content="<%= pageTitle %>">
  <meta name="twitter:description" content="<%= pageDescription %>">
  <meta name="twitter:image" content="<%-config.url + ogImage %>">
  <meta name="twitter:url" content="<%= url.replace(/index\.html$/, '') %>" />

  <!-- Mobile Specific Metas
  –––––––––––––––––––––––––––––––––––––––––––––––––– -->
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#<%= theme.tcolor %>">

  <!-- Preconnect to external origins
  –––––––––––––––––––––––––––––––––––––––––––––––––– -->
  <link rel="preconnect" href="https://www.googletagmanager.com" crossorigin>
  <link rel="dns-prefetch" href="https://www.googletagmanager.com">

  <!-- Preload fonts
  –––––––––––––––––––––––––––––––––––––––––––––––––– -->
  <link rel="preload" href="<%- url_for('/fonts/dm-serif-display-v4-latin-regular.woff2') %>" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="<%- url_for('/fonts/inter-v2-latin-regular.woff2') %>" as="font" type="font/woff2" crossorigin>

  <!-- CSS
  –––––––––––––––––––––––––––––––––––––––––––––––––– -->
  <%- css('css/normalize.css') %>
  <%- css('css/skeleton.css') %>
  <%- css('css/custom.css') %>
  <%- css('css/prism-dark.css') %>
  <%- css('css/prism-line-numbers.css') %>
  <!-- User css -->
  <% if (theme.usercss) { %>
  <%- css(theme.usercss) %>
  <% } %>

  <!-- Favicon
  –––––––––––––––––––––––––––––––––––––––––––––––––– -->
  <link rel="icon" type="image/png" href="<%- theme.favicon %>">

  <!-- Custom Theme Color Style
  –––––––––––––––––––––––––––––––––––––––––––––––––– -->
  <%- partial('partial/tcolor') %>

  <!-- Google Analytics (With Privacy Settings On)
  –––––––––––––––––––––––––––––––––––––––––––––––––– -->
  <%- partial('partial/google_analytics') %>

  <%- partial('googleadds/headeradd') %>

  <!-- JSON-LD Structured Data
  –––––––––––––––––––––––––––––––––––––––––––––––––– -->
  <%
  if (is_post()) {
    var postDesc = strip_html(page.content).replace(/\s+/g, ' ').trim().substring(0, 200);
    var blogPostingData = {
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      "headline": page.title,
      "datePublished": page.date.toISOString(),
      "dateModified": (page.updated || page.date).toISOString(),
      "author": { "@type": "Person", "name": config.author, "url": config.url + "/About/" },
      "publisher": { "@type": "Person", "name": config.author, "url": config.url },
      "url": url.replace(/index\.html$/, ''),
      "mainEntityOfPage": url.replace(/index\.html$/, ''),
      "inLanguage": page_lang() === 'zh' ? 'zh-CN' : 'en',
      "description": postDesc
    };
    if (page.tags && page.tags.length) {
      blogPostingData.keywords = page.tags.map(function(t){ return t.name; });
    }
    var breadcrumbData = {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": config.url },
        { "@type": "ListItem", "position": 2, "name": page.title, "item": url.replace(/index\.html$/, '') }
      ]
    };
  %>
  <script type="application/ld+json"><%- JSON.stringify(blogPostingData) %></script>
  <script type="application/ld+json"><%- JSON.stringify(breadcrumbData) %></script>
  <%
  } else {
    var websiteData = {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": config.title,
      "url": config.url,
      "description": config.description,
      "inLanguage": ["en", "zh-CN"],
      "author": {
        "@type": "Person",
        "name": config.author,
        "url": config.url + "/About/",
        "jobTitle": "Software Engineer",
        "sameAs": [theme.github, theme.linkedin, theme.twitter]
      }
    };
  %>
  <script type="application/ld+json"><%- JSON.stringify(websiteData) %></script>
  <% } %>

  <!-- Language detection and redirect (only on first visit, non-blocking for returning users) -->
  <script>
  (function() {
    var stored = localStorage.getItem('preferredLang');
    if (stored) return;
    var path = window.location.pathname;
    var isZhPath = path === '/zh' || path.indexOf('/zh/') === 0;
    if (isZhPath) {
      localStorage.setItem('preferredLang', 'zh');
      return;
    }
    if (path !== '/') return;
    var bl = (navigator.language || navigator.userLanguage || 'en').toLowerCase();
    stored = bl.indexOf('zh') === 0 ? 'zh' : 'en';
    localStorage.setItem('preferredLang', stored);
    if (stored === 'zh') {
      window.location.replace('/zh/' + window.location.search + window.location.hash);
    }
  })();
  </script>

</head>

<body>
  <div class="container">
    <div class="row">
      <div>

        <%- partial('partial/header') %>
        <div class="trans">
          <%- body %>
          <%- partial('partial/footer') %>
        </div>
      </div>

    </div>

  </div>
  <script src="<%- theme.nanobar %>"></script>
  <script>
    var options = {
      classname: 'nanobar',
      id: 'myNanobar'
    };
    var nanobar = new Nanobar(options);
    nanobar.go(30);
    nanobar.go(76);
    nanobar.go(100);
  </script>

</body>

</html>
