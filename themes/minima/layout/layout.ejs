<!DOCTYPE html>
<html lang="<%= config.language || 'en' %>">

<head>

  <!-- Minima -->
  <!-- Hexo theme created by @adisaktijrs -->

  <!-- Basic Page Needs
  –––––––––––––––––––––––––––––––––––––––––––––––––– -->
  <meta charset="utf-8">

  <%
  if (!config.author) {
    config.author = ""
  }

  var siteName = config.title;
  var pageTitle = siteName;
  if (is_archive()){
    pageTitle = 'All Posts - ' + siteName;
  } else if (is_post()){
    pageTitle = page.title + ' | ' + siteName;
  } else if (is_page()){
    pageTitle = page.title + ' | ' + siteName;
  } else if (is_tag()){
    pageTitle = 'Posts Related to ' + page.tag + ' | ' + siteName;
  }

  var canonicalUrl = url.replace(/index\.html$/, '');

  var pageDesc = config.description;
  if (is_page() && page.description) {
    pageDesc = page.description;
  } else if (page.content) {
    pageDesc = strip_html(page.content).replace(/\n/g, ' ').trim().substring(0, 160);
  }

  var pageImage = config.url + (theme.thumbnail || '/images/thumbnail.jpg');
  if ((is_post() || is_page()) && page.thumbnail) {
    pageImage = config.url + page.thumbnail;
  }

  var ogType = 'website';
  if (is_post()) {
    ogType = 'article';
  }
  %>
  <title><%= pageTitle %></title>

  <!-- DNS Prefetch & Preconnect -->
  <link rel="dns-prefetch" href="//www.googletagmanager.com">
  <link rel="preconnect" href="https://www.googletagmanager.com" crossorigin>

  <!-- Canonical & Sitemap -->
  <% if (config.sitemap) { %>
  <link rel="sitemap" type="application/xml" href="<%- config.url + '/' + config.sitemap.path %>" />
  <% } %>
  <link rel="canonical" href="<%= canonicalUrl %>">
  <% if (config.feed) { %>
  <link rel="alternate" type="application/atom+xml" title="<%= config.title %>" href="<%- config.url + '/' + config.feed.path %>">
  <% } %>

  <!-- SEO Meta Tags -->
  <meta name="description" content="<%= pageDesc %>">
  <% if (is_post() && page.tags && page.tags.length) { %>
  <meta name="keywords" content="<%= page.tags.map(function(tag){ return tag.name; }).join(', ') %>">
  <% } else if (config.keywords) { %>
  <meta name="keywords" content="<%= config.keywords %>">
  <% } %>
  <meta name="author" content="<%- config.author %>">
  <meta name="robots" content="index, follow">

  <!-- Open Graph -->
  <meta property="og:site_name" content="<%= config.title %>" />
  <meta property="og:type" content="<%= ogType %>" />
  <meta property="og:title" content="<%= pageTitle %>" />
  <meta property="og:description" content="<%= pageDesc %>">
  <meta property="og:url" content="<%= canonicalUrl %>" />
  <meta property="og:image" content="<%- pageImage %>">
  <meta property="og:locale" content="en_US" />
  <% if (is_post()) { %>
  <meta property="article:published_time" content="<%= date_xml(page.date) %>" />
  <meta property="article:modified_time" content="<%= date_xml(page.updated || page.date) %>" />
  <meta property="article:author" content="<%= config.author %>" />
  <% if (page.tags && page.tags.length) { %>
  <% page.tags.forEach(function(tag){ %>
  <meta property="article:tag" content="<%= tag.name %>" />
  <% }); %>
  <% } %>
  <% } %>

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:site" content="@Clean993">
  <meta name="twitter:creator" content="@Clean993">
  <meta name="twitter:title" content="<%= pageTitle %>">
  <meta name="twitter:description" content="<%= pageDesc %>">
  <meta name="twitter:image" content="<%- pageImage %>">
  <meta name="twitter:url" content="<%= canonicalUrl %>" />

  <!-- Mobile Specific Metas
  –––––––––––––––––––––––––––––––––––––––––––––––––– -->
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <!-- JSON-LD Structured Data -->
  <% if (is_post()) { %>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "<%- canonicalUrl %>"
    },
    "headline": "<%- page.title.replace(/"/g, '\\"') %>",
    "description": "<%- pageDesc.replace(/"/g, '\\"') %>",
    "image": "<%- pageImage %>",
    "author": {
      "@type": "Person",
      "name": "<%- config.author %>",
      "url": "<%- config.url %>/About/"
    },
    "publisher": {
      "@type": "Organization",
      "name": "<%- config.title.replace(/"/g, '\\"') %>",
      "logo": {
        "@type": "ImageObject",
        "url": "<%- config.url %>/images/favicon.png"
      }
    },
    "datePublished": "<%- date_xml(page.date) %>",
    "dateModified": "<%- date_xml(page.updated || page.date) %>"
    <% if (page.tags && page.tags.length) { %>,
    "keywords": [<%= page.tags.map(function(tag){ return '"' + tag.name.replace(/"/g, '\\"') + '"'; }).join(', ') %>]
    <% } %>
  }
  </script>
  <% } else if (is_home()) { %>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "<%- config.title.replace(/"/g, '\\"') %>",
    "url": "<%- config.url %>",
    "description": "<%- config.description.replace(/"/g, '\\"') %>",
    "author": {
      "@type": "Person",
      "name": "<%- config.author %>"
    }
  }
  </script>
  <% } %>

  <!-- Preload fonts
  –––––––––––––––––––––––––––––––––––––––––––––––––– -->
  <link rel="preload" href="<%- config.root %>fonts/dm-serif-display-v4-latin-regular.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="<%- config.root %>fonts/inter-v2-latin-regular.woff2" as="font" type="font/woff2" crossorigin>

  <!-- CSS
  –––––––––––––––––––––––––––––––––––––––––––––––––– -->
  <%- css('css/normalize.css') %>
  <%- css('css/skeleton.css') %>
  <%- css('css/custom.css') %>
  <%- css('css/prism-dark.css') %>
  <%- css('css/prism-line-numbers.css') %>
  <!-- User css -->
  <% if (theme.usercss) { %>
  <%- css(theme.usercss) %>
  <% } %>

  <!-- Favicon
  –––––––––––––––––––––––––––––––––––––––––––––––––– -->
  <link rel="icon" type="image/png" href="<%- theme.favicon %>">

  <!-- Custom Theme Color Style
  –––––––––––––––––––––––––––––––––––––––––––––––––– -->
  <%- partial('partial/tcolor') %>

  <!-- Google Analytics (With Privacy Settings On)
  –––––––––––––––––––––––––––––––––––––––––––––––––– -->
  <%- partial('partial/google_analytics') %>

  <%- partial('googleadds/headeradd') %>


</head>

<body>
  <div class="container">
    <div class="row">
      <div>

        <%- partial('partial/header') %>
        <div class="trans">
          <%- body %>
          <%- partial('partial/footer') %>
        </div>
      </div>

    </div>

  </div>
  <script src="<%- theme.nanobar %>"></script>
  <script>
    var options = {
      classname: 'nanobar',
      id: 'myNanobar'
    };
    var nanobar = new Nanobar(options);
    nanobar.go(30);
    nanobar.go(76);
    nanobar.go(100);
  </script>

</body>

</html>
