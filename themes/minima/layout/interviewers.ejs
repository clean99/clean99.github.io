<%
var currentLang = page.lang || page_lang();
var posts = interviewer_posts(6, currentLang);
%>

<article class="page-shell">
  <header class="page-hero">
    <p class="eyebrow">For interviewers</p>
    <h1>For Interviewers</h1>
    <p>I&rsquo;m a software engineer focused on building reliable, performant, and maintainable frontend systems. Recently, I&rsquo;ve also been exploring AI-assisted development and agentic workflows.</p>
    <p>If you&rsquo;re reviewing my work, these are the best starting points.</p>
  </header>

  <section class="section-block" aria-labelledby="engineering-focus-title">
    <div class="section-heading">
      <p class="eyebrow">Engineering focus</p>
      <h2 id="engineering-focus-title">Selected essays</h2>
    </div>
    <div class="post-list">
      <% posts.forEach(function(post) { %>
        <%- partial('partial/post_card', { post: post }) %>
      <% }) %>
    </div>
  </section>

  <section class="section-block" aria-labelledby="interviewer-projects-title">
    <div class="section-heading">
      <p class="eyebrow">Projects / experiments</p>
      <h2 id="interviewer-projects-title">Project notes from existing writing</h2>
    </div>
    <p>Selected projects will be expanded here as standalone project pages. For now, the strongest evidence lives in the engineering and AI writeups above, plus the project notes below.</p>
    <div class="project-list">
      <% project_posts(currentLang).slice(0, 3).forEach(function(post) { %>
        <article class="project-card">
          <h3><a href="<%- url_for(post.path) %>"><%- post.title %></a></h3>
          <p><%- post_summary(post, 150) %></p>
          <div class="tag-list">
            <% post_tag_names(post).slice(0, 4).forEach(function(tag) { %>
              <span><%- tag %></span>
            <% }) %>
          </div>
        </article>
      <% }) %>
    </div>
  </section>

  <section class="section-block" aria-labelledby="care-title">
    <div class="section-heading">
      <p class="eyebrow">Engineering taste</p>
      <h2 id="care-title">What I care about</h2>
    </div>
    <ul class="compact-list">
      <li>Reliable frontend systems</li>
      <li>Clear abstractions and maintainable code</li>
      <li>Performance under real-world constraints</li>
      <li>AI-assisted engineering workflows</li>
    </ul>
  </section>

  <section class="section-block" aria-labelledby="contact-title">
    <div class="section-heading">
      <p class="eyebrow">Contact</p>
      <h2 id="contact-title">Where to go next</h2>
    </div>
    <p>
      <a href="<%- lang_url('/About') %>">About</a>
      <% if (theme.email) { %> · <a href="mailto:<%= theme.email %>">Email</a><% } %>
      <% if (theme.github) { %> · <a href="<%- theme.github %>" target="_blank" rel="noreferrer">GitHub</a><% } %>
    </p>
  </section>
</article>
