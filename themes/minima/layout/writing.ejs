<%
var currentLang = page.lang || page_lang();
var areas = [
  ['engineering', area_label('engineering')],
  ['ai', area_label('ai')],
  ['systems', area_label('systems')],
  ['mind', area_label('mind')],
  ['life', area_label('life')]
];
var allPosts = posts_for_lang(currentLang);
var copy = currentLang === 'zh' ? {
  eyebrow: '写作',
  title: '写作',
  intro: '关于 software、AI、systems、learning 与 inner practice 的文章和笔记。',
  all: '全部',
  comingSoon: '即将补充。',
  archiveEyebrow: '归档',
  archiveTitle: '全部文章'
} : {
  eyebrow: 'Writing',
  title: 'Writing',
  intro: 'Essays and notes on software, AI, systems, learning, and inner practice.',
  all: 'All',
  comingSoon: 'Coming soon.',
  archiveEyebrow: 'Archive',
  archiveTitle: 'All posts'
};
%>

<article class="page-shell">
  <header class="page-hero">
    <p class="eyebrow"><%- copy.eyebrow %></p>
    <h1><%- copy.title %></h1>
    <p><%- copy.intro %></p>
  </header>

  <nav class="area-nav" aria-label="Writing sections">
    <a href="#all"><%- copy.all %></a>
    <% areas.forEach(function(area) { %>
      <a href="#<%- area[0] %>"><%- area[1] %></a>
    <% }) %>
  </nav>

  <% areas.forEach(function(area) { var posts = posts_in_area(area[0], 6, currentLang); %>
    <section class="section-block" id="<%- area[0] %>" aria-labelledby="<%- area[0] %>-title">
      <div class="section-heading">
        <p class="eyebrow"><%- area[1] %></p>
        <h2 id="<%- area[0] %>-title"><%- area[1] %></h2>
      </div>
      <% if (posts.length) { %>
        <div class="post-list">
          <% posts.forEach(function(post) { %>
            <%- partial('partial/post_card', { post: post }) %>
          <% }) %>
        </div>
      <% } else { %>
        <p class="muted"><%- copy.comingSoon %></p>
      <% } %>
    </section>
  <% }) %>

  <section class="section-block" id="all" aria-labelledby="all-posts-title">
    <div class="section-heading">
      <p class="eyebrow"><%- copy.archiveEyebrow %></p>
      <h2 id="all-posts-title"><%- copy.archiveTitle %></h2>
    </div>
    <div class="archive-list">
      <% allPosts.forEach(function(post) { %>
        <div class="archive-list__item">
          <time datetime="<%= post.date.toISOString() %>"><%- full_date(post.date, 'll') %></time>
          <span class="pill"><%- area_label(post_area(post)) %></span>
          <a href="<%- url_for(post.path) %>"><%- post.title || 'Untitled' %></a>
        </div>
      <% }) %>
    </div>
  </section>
</article>
