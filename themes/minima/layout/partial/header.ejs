<header class="site-header">
  <div class="site-header__top">
    <div class="site-actions">
      <button class="theme-toggle" type="button" onclick="setDarkMode(!document.body.classList.contains('darkmode'))" aria-label="Toggle color theme">
        <span id="themeIcon" aria-hidden="true">◐</span>
      </button>
      <a
        href="<%- alternate_url() %>"
        class="language-switch"
        onclick="localStorage.setItem('preferredLang', '<%= is_zh() ? 'en' : 'zh' %>')"
        aria-label="<%= __('post.lang_switch') %>"
      ><%= is_zh() ? 'EN' : '中文' %></a>
    </div>
  </div>

  <nav class="site-nav" aria-label="Primary navigation">
    <a href="<%- lang_root() %>"><%= __('nav.home') %></a>
    <% for (name in theme.menu) { %>
      <% if (theme.menu[name]) { %>
        <a href="<%- lang_url(theme.menu[name]) %>"><%- __('nav.' + name.toLowerCase()) %></a>
      <% } %>
    <% } %>
  </nav>
</header>

<script>
  if (localStorage.getItem('preferredTheme') === 'dark') {
    setDarkMode(true);
  }
  function setDarkMode(isDark) {
    document.body.classList.toggle('darkmode', isDark);
    var icon = document.getElementById('themeIcon');
    if (icon) icon.textContent = isDark ? '◑' : '◐';
    if (isDark) {
      localStorage.setItem('preferredTheme', 'dark');
    } else {
      localStorage.removeItem('preferredTheme');
    }
  }
</script>
