<section>
  <%
    var tagTitle = '';
    if (page.category) tagTitle = page.category;
    if (page.tag) tagTitle = page.tag;
    if (page.archive){
        if (page.year) tagTitle = page.year + (page.month ? '/' + page.month : '');
        else tagTitle = "Archives";
    }
  %>
  <% if(tagTitle) { %>
  <h1>Posts Related to &mdash; <%- tagTitle %></h1>
  <% } %>
  <% page.posts.each(function(item){ %>

  <article class="row">
    <div class="three columns left lit">
      <time class="bottom" datetime="<%= date_xml(item.date) %>"><%- full_date(item.date, 'll') %></time>
    </div>
    <div class="nine columns left mb-3">
      <a href="<%- url_for(item.path) %>">
        <% if (item.title == "") { %>
          no title
        <% } else { %>
          <%- item.title %>
        <% } %>
      </a>
    </div>
  </article>

  <% }); %>
  <%- partial('partial/pagination') %>
</section>
