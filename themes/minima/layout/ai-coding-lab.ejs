<%
var currentLang = page_lang();
var copy = currentLang === 'zh' ? {
  eyebrow: '公开 Agent 工作台',
  title: 'AI Coding Skills',
  intro: '我创建的 AI coding skills 会从私有 setup 仓库实时生成并同步到这里。页面只展示自建 skills 和关键 agent 配置的脱敏公开内容。',
  statementTitle: '作者声明',
  statement: '这些 skills 和配置是我的日常 AI 编程工作流样本。页面不会发布密钥、内部平台细节、个人路径或私有仓库入口；可点击内容已在生成阶段脱敏。',
  pipeline: '更新流水线',
  pipelineSteps: ['监听 setup 更新', '筛选自建 skills 与 agent 配置', '生成脱敏内容预览', '发布静态 catalog'],
  controlsLabel: '筛选目录',
  search: '搜索 skills、配置、类别或内容',
  all: '全部',
  skills: 'Skills',
  files: '配置文件',
  redacted: '脱敏内容',
  status: '同步状态',
  generated: '生成时间',
  commit: '源提交'
} : {
  eyebrow: 'Public Agent Workbench',
  title: 'AI Coding Skills',
  intro: 'A live catalog of the AI coding skills I created, generated from my private setup repository. It publishes only self-authored skills and key agent configuration in sanitized form.',
  statementTitle: 'Author Statement',
  statement: 'These skills and configuration files are part of my day-to-day AI coding workflow. This page does not publish credentials, internal platform details, personal paths, or private repository entry points; clickable content is sanitized during generation.',
  pipeline: 'Update Pipeline',
  pipelineSteps: ['Watch setup updates', 'Select authored skills and agent config', 'Generate sanitized previews', 'Publish static catalog'],
  controlsLabel: 'Filter catalog',
  search: 'Search skills, config, categories, or content',
  all: 'All',
  skills: 'Skills',
  files: 'Config files',
  redacted: 'Sanitized',
  status: 'Sync status',
  generated: 'Generated',
  commit: 'Source commit'
};
%>

<article
  class="ai-lab"
  data-catalog-url="<%- url_for('/ai-coding-lab/catalog.json') %>"
  data-lang="<%- currentLang %>"
>
  <header class="ai-lab__hero">
    <div class="ai-lab__hero-copy">
      <p class="eyebrow"><%- copy.eyebrow %></p>
      <h1><%- copy.title %></h1>
      <p><%- copy.intro %></p>
    </div>

    <div class="ai-lab__schematic" aria-label="<%- copy.pipeline %>">
      <% copy.pipelineSteps.forEach(function(step, index) { %>
        <div class="ai-lab__node">
          <span><%- String(index + 1).padStart(2, '0') %></span>
          <strong><%- step %></strong>
        </div>
      <% }) %>
    </div>
  </header>

  <section class="ai-lab__statement">
    <div>
      <p class="eyebrow"><%- copy.statementTitle %></p>
      <p><%- copy.statement %></p>
    </div>
    <dl class="ai-lab__meta">
      <div>
        <dt><%- copy.status %></dt>
        <dd id="aiCatalogStatus">Loading</dd>
      </div>
      <div>
        <dt><%- copy.generated %></dt>
        <dd id="aiCatalogGenerated">-</dd>
      </div>
      <div>
        <dt><%- copy.commit %></dt>
        <dd id="aiCatalogCommit">-</dd>
      </div>
    </dl>
  </section>

  <section class="ai-lab__stats" id="aiCatalogStats" aria-live="polite"></section>

  <section class="ai-lab__controls" aria-label="<%- copy.controlsLabel %>">
    <label class="ai-lab__search">
      <span><%- copy.search %></span>
      <input id="aiCatalogSearch" type="search" autocomplete="off" />
    </label>
    <div class="ai-lab__filters" role="group" aria-label="<%- copy.controlsLabel %>">
      <button type="button" class="is-active" data-filter="all"><%- copy.all %></button>
      <button type="button" data-filter="skill"><%- copy.skills %></button>
      <button type="button" data-filter="file"><%- copy.files %></button>
      <button type="button" data-filter="redacted"><%- copy.redacted %></button>
    </div>
  </section>

  <section class="ai-lab__catalog" id="aiCatalogItems" aria-live="polite"></section>
</article>
